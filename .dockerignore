# Python
**/__pycache__/
**/*.pyc
backend/.venv/
backend/venv/

# Node / frontend build (the backend image does not need the frontend)
frontend/

# Runtime-generated storage (recreated on startup)
backend/app/storage/uploads/
backend/app/storage/overlays/
backend/app/storage/sessions/
backend/app/storage/debug/

# Raw source clips are only used by the dataset build script, not at runtime.
# The backend serves from the committed dataset/shots and dataset/players indexes.
dataset/batting/
dataset/bowling/
dataset/clips/

# Misc
.git/
.gitignore
*.md
.env
**/.env
