# ──────────────────────────────────────────────────────────────
# Firebase CLIENT config (safe to expose — these are public keys)
# Firebase Console → Project settings → General → Your apps → Web app
# ──────────────────────────────────────────────────────────────
# Storage mode: false = analyse clips directly via the ML service (no Blaze needed);
# true = upload clips to Firebase Storage first (requires the Blaze plan).
NEXT_PUBLIC_ENABLE_STORAGE=false

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ──────────────────────────────────────────────────────────────
# Firebase ADMIN config (server-only — KEEP SECRET)
# Firebase Console → Project settings → Service accounts → Generate new private key
# Paste the private key with literal \n escapes, wrapped in double quotes.
# ──────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ──────────────────────────────────────────────────────────────
# ML inference endpoint — the real pose-based recognizer in ml-service/.
# Run it locally with uvicorn (see ml-service/README.md), or deploy to Render.
# If unset, /api/predict uses the built-in mock inference.
# ──────────────────────────────────────────────────────────────
ML_INFERENCE_URL=http://127.0.0.1:8000/predict

# ──────────────────────────────────────────────────────────────
# AI Coach (Google Gemini). If GEMINI_API_KEY is unset, the coach falls back
# to built-in rule-based feedback. Get a key: https://aistudio.google.com/apikey
# ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
