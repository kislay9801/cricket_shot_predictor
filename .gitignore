# Raw source clips: input to the dataset build script only, NOT needed at runtime.
# The app serves from the committed dataset/shots and dataset/players JSON indexes.
# Folder structure is preserved via the .gitkeep files.
*.mp4
*.mov
*.avi
*.mkv
*.webm
!**/.gitkeep
